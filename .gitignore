.claude/settings.local.json

# runtime artifacts (never track)
*.pid
logs/

# env variants & browser auth state (execution layer red line)
.env.*
!.env.example
storage_state*.json
reports/**/*.log

# medic runtime artifacts (写盘留证,不入库)
team/health.md
team/health_alerts.log
team/tsay_failures.log


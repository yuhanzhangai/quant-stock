# ===== LEGACY(QuantLab crypto 时代,C2 退役 src/exchange 时移除)=====
# OKX API 配置(只读权限)——quant-stock 不再需要申请,留空即可
OKX_API_KEY=your_api_key_here
OKX_API_SECRET=your_api_secret_here
OKX_PASSPHRASE=your_passphrase_here
OKX_USE_SIMULATED=0

# ===== quant-stock 通用 =====
# Telegram 通知(可选)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 日志级别
LOG_LEVEL=INFO

# 数据目录
DATA_DIR=data

# ===== 执行层(Firstrade 模拟盘,C5+ 启用)=====
# 注意:登录态/cookie 绝不写进 .env,统一存 gitignored 的 .auth/ 路径
# PAPER_ONLY 为硬钉安全闸,执行层代码启动时断言其为 1
PAPER_ONLY=1
